<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Define the paths you want to share. Examples: -->

    <!-- To share files in your app's internal cache directory -->
    <cache-path name="my_cache" path="." />

    <!-- To share files in your app's internal files directory -->
    <files-path name="my_files" path="." />

    <!-- To share files in the root of the external storage (use with caution) -->
    <!-- Make sure you have the necessary permissions -->
    <external-path name="my_external_files" path="." />

    <!-- To share files in your app's dedicated external cache directory -->
    <external-cache-path name="my_external_cache" path="." />

    <!-- To share files in your app's dedicated external files directory -->
    <external-files-path name="my_external_files_dir" path="." />

    <!-- Add more paths as needed -->
</paths>