<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".GraphActivity"
    tools:showIn="@layout/activity_graph">

<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/coordinator"
android:layout_width="match_parent"
android:layout_height="wrap_content"
    android:padding="16dp">

<com.google.android.material.textfield.TextInputLayout
android:id="@+id/textInputLayoutFormulaX"
style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_marginTop="0dp"
    android:hint="@string/hint_formula_x"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

<com.google.android.material.textfield.TextInputEditText
android:id="@+id/editTextFormulaX"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:inputType="textNoSuggestions" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- The commented out textInputLayoutFormulaY is skipped as per the original file -->

<com.google.android.material.textfield.TextInputLayout
android:id="@+id/textInputLayoutFormulaFx"
style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_marginTop="8dp"
android:hint="@string/hint_formula_fx"
app:layout_constraintTop_toBottomOf="@+id/textInputLayoutFormulaX"
app:layout_constraintStart_toStartOf="parent"
app:layout_constraintEnd_toEndOf="parent">

<com.google.android.material.textfield.TextInputEditText
    android:id="@+id/editTextFormulaFx"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:inputType="textNoSuggestions" />
</com.google.android.material.textfield.TextInputLayout>

    <!-- X MIN AND X MAX LinearLayout -->
<LinearLayout
android:id="@+id/layoutXMinMax"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:orientation="horizontal"
android:layout_marginTop="8dp"
app:layout_constraintTop_toBottomOf="@+id/textInputLayoutFormulaFx"
app:layout_constraintStart_toStartOf="parent"
app:layout_constraintEnd_toEndOf="parent"
android:weightSum="1">

<com.google.android.material.textfield.TextInputLayout
    android:id="@+id/textInputLayoutXMin"
    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
    android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_weight="0.5"
android:hint="@string/hint_x_min"
app:errorEnabled="true"
android:layout_marginEnd="4dp">

<com.google.android.material.textfield.TextInputEditText
    android:id="@+id/editTextXMin"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:inputType="numberDecimal|numberSigned"
    android:text="-10" />
</com.google.android.material.textfield.TextInputLayout>

<com.google.android.material.textfield.TextInputLayout
android:id="@+id/textInputLayoutXMax"
style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="0.5"
    android:hint="@string/hint_x_max"
    app:errorEnabled="true"
    android:layout_marginStart="4dp">

<com.google.android.material.textfield.TextInputEditText
android:id="@+id/editTextXMax"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:inputType="numberDecimal|numberSigned"
android:text="10" />
    </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- NEW Y MIN AND Y MAX LinearLayout -->
<LinearLayout
android:id="@+id/layoutYMinMax"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:orientation="horizontal"
android:layout_marginTop="8dp"
app:layout_constraintTop_toBottomOf="@+id/layoutXMinMax"
app:layout_constraintStart_toStartOf="parent"
app:layout_constraintEnd_toEndOf="parent"
android:weightSum="2"> <!-- Weight sum adjusted for clarity, though 1 would also work -->

<com.google.android.material.textfield.TextInputLayout
    android:id="@+id/textInputLayoutYMin"
    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
    android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_weight="1"
android:hint="@string/hint_y_min"
android:layout_marginEnd="4dp"
app:errorEnabled="true">
<com.google.android.material.textfield.TextInputEditText
    android:id="@+id/editTextYMin"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
android:inputType="numberDecimal|numberSigned"
android:text="-10" />
</com.google.android.material.textfield.TextInputLayout>

<com.google.android.material.textfield.TextInputLayout
android:id="@+id/textInputLayoutYMax"
style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:hint="@string/hint_y_max"
    android:layout_marginStart="4dp"
    app:errorEnabled="true">
<com.google.android.material.textfield.TextInputEditText
android:id="@+id/editTextYMax"
android:layout_width="match_parent"
android:layout_height="wrap_content"
    android:inputType="numberDecimal|numberSigned"
    android:text="10" />
    </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

<Button
android:id="@+id/buttonPlot"
android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:text="@string/button_plot"
    android:visibility="gone"
    app:layout_constraintTop_toBottomOf="@+id/layoutYMinMax"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    tools:visibility="visible" />

<FrameLayout
android:id="@+id/frameLayoutImageView"
android:layout_width="0dp"
android:layout_height="0dp"
    android:layout_marginTop="16dp"
    android:background="@android:color/darker_gray"
    app:layout_constraintTop_toBottomOf="@+id/buttonPlot"
    app:layout_constraintBottom_toBottomOf="@+id/coordinator"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintVertical_bias="0.0"> <!-- Ensures it starts right after the button -->
    <!-- Consider adding a minHeight to frameLayoutImageView if it can become too small -->
    <!-- e.g., android:minHeight="200dp" -->

<ImageView
android:id="@+id/imageViewGraph"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:scaleType="fitCenter"
android:contentDescription="@string/content_description_graph_image" />

<Button
android:id="@+id/buttonDownloadImage"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:layout_gravity="bottom|end"
android:layout_margin="8dp"
android:text="@string/button_download_image"
android:visibility="gone"
tools:visibility="visible" />
    </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>