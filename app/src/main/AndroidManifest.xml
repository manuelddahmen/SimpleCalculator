<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:versionName="3.0"
    package="one.empty3.apps.simplecalculator">

    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="34"
        />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="34"
        />
    <application
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="true"
        android:exported="true"
        android:hardwareAccelerated="true"
        android:icon="@drawable/calcphotoshopexpress"
        android:installLocation="auto"
        android:label="@string/app_name"
        android:roundIcon="@drawable/calcphotoshopexpress_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SimpleCalculator"
        android:usesCleartextTraffic="true"
        tools:remove="android:appComponentFactory"
        tools:targetApi="tiramisu"
        android:name="one.empty3.apps.simplecalculator.SciProgCalculator">
        <!--
        tools:ignore="UnusedAttribute"
        tools:remove="android:appComponentFactory"
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="one.empty3.apps.simplecalculator.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>


        <activity
            android:exported="false"
            android:name="one.empty3.apps.simplecalculator.GraphActivity" /> <!-- Ajustez 'exported' selon vos besoins -->
        <!-- ... autres activités ... -->
        <activity
            android:exported="false" android:label="@string/title_activity_privacy_policy"
            android:name="one.empty3.apps.simplecalculator.PrivacyPolicyActivity" />
        <activity
            android:exported="false"
            android:label="@string/title_activity_settings"
            android:name="one.empty3.apps.simplecalculator.SettingsActivity" />
        <activity
            android:exported="false"
            android:label="@string/title_activity_scrolling"
            android:theme="@style/Theme.SimpleCalculator"
            android:name="one.empty3.apps.simplecalculator.ScrollingActivity" />
        <activity
            android:label="License text"
            android:exported="false"
            android:name="one.empty3.apps.simplecalculator.LicenceUserData" /> <!-- <a href="https://www.flaticon.com/free-icons/electronics" title="electronics icons">Electronics icons created by 88 Cloud - Flaticon</a> -->
        <activity
            android:label="3D activity"
            android:exported="true"
            android:name="one.empty3.apps.simplecalculator.MyActivity" />

        <activity
            android:exported="true"
            android:label="Sci-prog Calculator"
            android:theme="@style/Theme.SimpleCalculator"
            android:name="one.empty3.apps.simplecalculator.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>